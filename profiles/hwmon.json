{
  "$schema": "schema/config.schema.json",
  "config_name": "Hardware Monitor",
  "refresh_rate_ms": 1000,
  "display": {
    "width": 128,
    "height": 40,
    "background": 0
  },
  "widgets": [
    {
      "type": "hwmon",
      "enabled": true,
      "position": {
        "x": 0,
        "y": 0,
        "w": 42,
        "h": 20,
        "z": 0
      },
      "style": {
        "background": 0,
        "border": -1,
        "padding": 0
      },
      "mode": "text",
      "hwmon": {
        "sensor_type": "Temperature",
        "sensor_filter": "amdcpu",
        "max": 100
      },
      "text": {
        "font": null,
        "size": 10,
        "align": {
          "h": "center",
          "v": "center"
        }
      },
      "update_interval": 2
    },
    {
      "type": "hwmon",
      "enabled": true,
      "position": {
        "x": 43,
        "y": 0,
        "w": 42,
        "h": 20,
        "z": 0
      },
      "style": {
        "background": 0,
        "border": -1,
        "padding": 0
      },
      "mode": "text",
      "hwmon": {
        "sensor_type": "Temperature",
        "sensor_filter": "gpu",
        "max": 100
      },
      "text": {
        "font": null,
        "size": 10,
        "align": {
          "h": "center",
          "v": "center"
        }
      },
      "update_interval": 2
    },
    {
      "type": "hwmon",
      "enabled": true,
      "position": {
        "x": 0,
        "y": 20,
        "w": 128,
        "h": 20,
        "z": 0
      },
      "style": {
        "background": 0,
        "border": -1,
        "padding": 0
      },
      "mode": "graph",
      "hwmon": {
        "sensor_type": "Load",
        "sensor_filter": "CPU Total",
        "max": 100
      },
      "graph": {
        "history": 128,
        "colors": {
          "fill": 255,
          "line": 255
        }
      },
      "update_interval": 1
    }
  ]
}
